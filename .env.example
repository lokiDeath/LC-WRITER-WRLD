# ─────────────────────────────────────────────────────────────
# LC Novel Studio — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` for local development, or set these
# in your Vercel project settings for production.
# All values are optional — the build will not crash if any are missing.

# ─── Database (REQUIRED for production) ───
# Prisma PostgreSQL connection. Get one from Neon, Supabase, or Render.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public"

# ─── AI Provider (used by /api/chat and /api/studio/import) ───
# Provided by Z.AI — falls back to empty string if unset.
GEMINI_API_KEY=""
# Optional overrides. The defaults are gemini-2.5-flash for general chat and
# gemini-2.5-pro for the project writing co-pilot.
GEMINI_MAIN_MODEL="gemini-2.5-flash"
GEMINI_COPILOT_MODEL="gemini-2.5-pro"

# ─── Image Generation (priority order: Fal.ai → RunPod → ComfyUI → ZAI) ───
# Set ONE of these. If none are set, falls back to ZAI image generation.
FAL_KEY=""
FAL_MODEL="fal-ai/flux/schnell"

RUNPOD_API_KEY=""
RUNPOD_ENDPOINT_ID=""

COMFYUI_HOST=""

# ─── OAuth Providers (optional — buttons gracefully show 503 if unset) ───
GOOGLE_CLIENT_ID=""
GOOGLE_REDIRECT_URI=""

DISCORD_CLIENT_ID=""
DISCORD_REDIRECT_URI=""

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

ONENOTE_CLIENT_ID=""
ONENOTE_CLIENT_SECRET=""

# ─── Misc ───
NODE_ENV="production"
